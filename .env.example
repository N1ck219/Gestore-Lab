# ======================================================================
# 🧪 Gestore-Lab: File delle Configurazioni Ambientali (.env)
# ======================================================================
# Modificare questo file per adattare l'applicazione a percorsi locali,
# porte di rete e chiavi segrete senza dover alterare il codice Python.

# 🖥️ Configurazione del Server Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True
SECRET_KEY=inserisci_qui_una_chiave_segreta_sicura

# 💾 Configurazione Database SQLite
# DB_PATH: Percorso del file database attivo. Può essere relativo o assoluto.
DB_PATH=database/database.db

# BACKUP_DIR: Cartella contenente le copie storiche dei backup del database.
BACKUP_DIR=database/backups

# 📄 Configurazione Cartelle per i Documenti PDF Generati
# I percorsi possono essere relativi alla radice del progetto o assoluti.
LISTA_DISTRIBUZIONE_DIR=lista_distribuzione
RICHIESTA_ANALISI_DIR=richiesta_analisi
PICKING_LIST_DIR=picking_list

# 📋 Percorso Registro Log di Sistema
APP_LOG_PATH=database/app.log

